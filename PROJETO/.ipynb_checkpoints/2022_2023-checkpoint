    "import pandas as pd\n",
    "import time\n",
    "import os\n",
    "from datetime import datetime\n",
    "from unidecode import unidecode\n",
    "import warnings\n",
    "from pathlib import Path\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# ✅ PRIMEIRO: Recriar a classe básica do processador para teste\n",
    "class ProcessadorTeste:\n",
    "    def __init__(self):\n",
    "        self.config = {\n",
    "            \"coluna_endereco\": \"logradouro\",\n",
    "            \"coluna_numero\": \"numero_logradouro\"\n",
    "        }\n",
    "        self._importar_modulos_teste()\n",
    "    \n",
    "    def _importar_modulos_teste(self):\n",
    "        \"\"\"Importa apenas os módulos necessários para o teste\"\"\"\n",
    "        try:\n",
    "            from buscaEndereco_CET_v12_0 import buscar_endereco_candidatos, enriquecer_candidatos_geoserver\n",
    "            self.buscar_endereco_candidatos = buscar_endereco_candidatos\n",
    "            self.enriquecer_candidatos_geoserver = enriquecer_candidatos_geoserver\n",
    "            print(\"✅ Módulos de busca importados com sucesso!\")\n",
    "        except ImportError as e:\n",
    "            print(f\"❌ Erro na importação: {e}\")\n",
    "            raise\n",
    "    \n",
    "    def _processar_numero_resiliente(self, numero):\n",
    "        \"\"\"Processa número de forma resiliente\"\"\"\n",
    "        if numero is None or pd.isna(numero):\n",
    "            return \"\"\n",
    "        \n",
    "        if isinstance(numero, (int, float)):\n",
    "            return str(int(numero)) if numero > 0 else \"\"\n",
    "        \n",
    "        numero_str = str(numero).strip()\n",
    "        if numero_str in ['', '0', '0.0', 'NaN', 'nan', 'None', 'null']:\n",
    "            return \"\"\n",
    "        \n",
    "        if numero_str.endswith('.0'):\n",
    "            numero_str = numero_str[:-2]\n",
    "        \n",
    "        return numero_str\n",
    "    \n",
    "    def _criar_resultado_fallback(self, row, index, motivo):\n",
    "        \"\"\"Cria resultado de fallback padronizado\"\"\"\n",
    "        dados_base = {\n",
    "            \"linha_origem\": index + 1,\n",
    "            \"status_processamento\": \"FALLBACK\",\n",
    "            \"motivo_status\": motivo,\n",
    "            \"timestamp_processamento\": datetime.now().isoformat(),\n",
    "            \"latitude_geocode\": None,\n",
    "            \"longitude_geocode\": None,\n",
    "            \"codlog\": None,\n",
    "            \"logradouro_PMSP\": None,\n",
    "            \"similaridade\": None,\n",
    "            \"distancia_km\": None,\n",
    "            \"_fonte_busca\": \"FALLBACK\"\n",
    "        }\n",
    "        \n",
    "        # Adicionar colunas originais\n",
    "        for col in row.keys():\n",
    "            if col not in dados_base:\n",
    "                dados_base[col] = row[col]\n",
    "        \n",
    "        return pd.DataFrame([dados_base])\n",
    "\n",
    "    def _processar_registro_teste(self, row, index):\n",
    "        \"\"\"Processa um registro individual - VERSÃO TESTE\"\"\"\n",
    "        try:\n",
    "            logradouro = str(row.get(self.config[\"coluna_endereco\"], \"\"))\n",
    "            \n",
    "            # ✅ PROCESSAR NÚMERO\n",
    "            numero = row.get(self.config[\"coluna_numero\"], \"\")\n",
    "            numero_processado = self._processar_numero_resiliente(numero)\n",
    "\n",
    "            # ✅ VALIDAR COORDENADAS\n",
    "            lat_original = row.get('latitude_original')\n",
    "            lon_original = row.get('longitude_original')\n",
    "            \n",
    "            if pd.isna(lat_original) or pd.isna(lon_original):\n",
    "                return self._criar_resultado_fallback(row, index, \"COORDENADAS_INVALIDAS\")\n",
    "            \n",
    "            # ✅ BUSCA DE CANDIDATOS COM DEBUG\n",
    "            print(f\"🎯 DEBUG: Buscando endereco='{logradouro}', numero='{numero_processado}'\")\n",
    "            print(f\"📍 DEBUG: Coord orig: ({lat_original}, {lon_original})\")\n",
    "            \n",
    "            df_candidatos = self.buscar_endereco_candidatos(\n",
    "                endereco=logradouro,\n",
    "                numero=numero_processado,\n",
    "                lat_origem=lat_original,\n",
    "                lon_origem=lon_original,\n",
    "                max_candidatos=10\n",
    "            )\n",
    "            \n",
    "            # ✅ DEBUG DOS RESULTADOS\n",
    "            print(f\"📊 DEBUG: {len(df_candidatos)} candidatos encontrados\")\n",
    "            if not df_candidatos.empty:\n",
    "                primeiro = df_candidatos.iloc[0]\n",
    "                print(f\"📍 DEBUG: Primeiro - {primeiro.get('logradouro_PMSP', 'N/A')}\")\n",
    "                print(f\"📍 DEBUG: Coord - ({primeiro.get('latitude_geocode', 'N/A')}, {primeiro.get('longitude_geocode', 'N/A')})\")\n",
    "                \n",
    "            # ✅ PROCESSAR RESULTADOS\n",
    "            if (isinstance(df_candidatos, pd.DataFrame) and not df_candidatos.empty and \n",
    "                df_candidatos.iloc[0].get(\"logradouro_PMSP\") != \"NAO ENCONTRADO\"):\n",
    "                \n",
    "                # Ordenar por qualidade\n",
    "                if \"distancia_km\" in df_candidatos.columns:\n",
    "                    df_ordenado = df_candidatos.sort_values(by=\"distancia_km\", ascending=True)\n",
    "                else:\n",
    "                    df_ordenado = df_candidatos\n",
    "                \n",
    "                melhor_candidato = df_ordenado.iloc[0]\n",
    "                \n",
    "                # Enriquecer\n",
    "                df_melhor_candidato = pd.DataFrame([melhor_candidato])\n",
    "                df_enriquecido = self.enriquecer_candidatos_geoserver(df_melhor_candidato)\n",
    "                \n",
    "                if not df_enriquecido.empty:\n",
    "                    df_result = df_enriquecido.copy()\n",
    "                else:\n",
    "                    df_result = df_melhor_candidato.copy()\n",
    "                \n",
    "                # ✅ METADADOS\n",
    "                df_result[\"linha_origem\"] = index + 1\n",
    "                df_result[\"status_processamento\"] = \"SUCESSO\"\n",
    "                df_result[\"motivo_status\"] = None\n",
    "                df_result[\"timestamp_processamento\"] = datetime.now().isoformat()\n",
    "                \n",
    "                # ✅ PRESERVAR COLUNAS ORIGINAIS\n",
    "                for col in row.keys():\n",
    "                    if col not in df_result.columns:\n",
    "                        df_result[col] = row[col]\n",
    "                \n",
    "                return df_result\n",
    "            else:\n",
    "                return self._criar_resultado_fallback(row, index, \"SEM_CANDIDATOS\")\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"💥 ERRO no processamento: {e}\")\n",
    "            return self._criar_resultado_fallback(row, index, f\"ERRO_PROCESSAMENTO: {str(e)[:50]}\")\n",
    "\n",
    "# ✅ SEGUNDO: Função de teste completa\n",
    "def teste_processamento_manual():\n",
    "    \"\"\"Rotina de teste manual para diagnosticar o problema dos números\"\"\"\n",
    "    print(\"🧪 INICIANDO TESTE MANUAL - DIAGNÓSTICO DE NÚMEROS\")\n",
    "    print(\"=\" * 80)\n",
    "    \n",
    "    # Criar processador de teste\n",
    "    processor = ProcessadorTeste()\n",
    "    \n",
    "    # Dados de teste baseados nos seus registros problemáticos\n",
    "    testes = [\n",
    "        {\n",
    "            \"id\": \"TESTE_1\", \n",
    "            \"logradouro\": \"AVENIDA DOS BANDEIRANTES\", \n",
    "            \"numero\": \"2040\", \n",
    "            \"lat\": -23.611386, \n",
    "            \"lon\": -46.674721\n",
    "        },\n",
    "        {\n",
    "            \"id\": \"TESTE_2\", \n",
    "            \"logradouro\": \"AVENIDA DOS BANDEIRANTES\", \n",
    "            \"numero\": \"5583\", \n",
    "            \"lat\": -23.62605783, \n",
    "            \"lon\": -46.64883482\n",
    "        },\n",
    "        {\n",
    "            \"id\": \"TESTE_3\", \n",
    "            \"logradouro\": \"AVENIDA SALIM FARAH MALUF\", \n",
    "            \"numero\": \"446\", \n",
    "            \"lat\": -23.57878922, \n",
    "            \"lon\": -46.57220426\n",
    "        },\n",
    "        {\n",
    "            \"id\": \"TESTE_4\", \n",
    "            \"logradouro\": \"AVENIDA SALIM FARAH MALUF\", \n",
    "            \"numero\": \"4288\", \n",
    "            \"lat\": -23.57939419, \n",
    "            \"lon\": -46.57223515\n",
    "        }\n",
    "    ]\n",
    "    \n",
    "    resultados_teste = []\n",
    "    \n",
    "    for i, teste in enumerate(testes, 1):\n",
    "        print(f\"\\n🔍 TESTE {i}: {teste['id']}\")\n",
    "        print(f\"   Endereço: {teste['logradouro']}, {teste['numero']}\")\n",
    "        \n",
    "        # Simular uma linha do DataFrame\n",
    "        row_simulada = {\n",
    "            \"logradouro\": teste[\"logradouro\"],\n",
    "            \"numero_logradouro\": teste[\"numero\"],\n",
    "            \"latitude_original\": teste[\"lat\"],\n",
    "            \"longitude_original\": teste[\"lon\"]\n",
    "        }\n",
    "        \n",
    "        # Processar como o processador faria\n",
    "        resultado = processor._processar_registro_teste(row_simulada, i)\n",
    "        \n",
    "        if resultado is not None and not resultado.empty:\n",
    "            coords = resultado[['latitude_geocode', 'longitude_geocode']].iloc[0]\n",
    "            logradouro_pmsp = resultado['logradouro_PMSP'].iloc[0]\n",
    "            fonte = resultado['_fonte_busca'].iloc[0] if '_fonte_busca' in resultado.columns else \"N/A\"\n",
    "            \n",
    "            print(f\"   ✅ RESULTADO:\")\n",
    "            print(f\"      Logradouro PMSP: {logradouro_pmsp}\")\n",
    "            print(f\"      Coordenadas: ({coords['latitude_geocode']}, {coords['longitude_geocode']})\")\n",
    "            print(f\"      Fonte: {fonte}\")\n",
    "            \n",
    "            # Armazenar para comparação\n",
    "            resultados_teste.append({\n",
    "                \"teste_id\": teste['id'],\n",
    "                \"logradouro\": teste['logradouro'],\n",
    "                \"numero\": teste['numero'],\n",
    "                \"coord_original\": (teste['lat'], teste['lon']),\n",
    "                \"coord_geocode\": (coords['latitude_geocode'], coords['longitude_geocode']),\n",
    "                \"logradouro_pmsp\": logradouro_pmsp,\n",
    "                \"fonte\": fonte\n",
    "            })\n",
    "        else:\n",
    "            print(f\"   ❌ SEM RESULTADO\")\n",
    "    \n",
    "    # 🔍 ANÁLISE COMPARATIVA\n",
    "    print(f\"\\n{'='*80}\")\n",
    "    print(\"📊 ANÁLISE COMPARATIVA DOS RESULTADOS\")\n",
    "    print(f\"{'='*80}\")\n",
    "    \n",
    "    # Agrupar por logradouro para comparar coordenadas\n",
    "    from collections import defaultdict\n",
    "    agrupados = defaultdict(list)\n",
    "    \n",
    "    for resultado in resultados_teste:\n",
    "        agrupados[resultado['logradouro']].append(resultado)\n",
    "    \n",
    "    for logradouro, registros in agrupados.items():\n",
    "        print(f\"\\n📋 {logradouro}:\")\n",
    "        coordenadas_unicas = set()\n",
    "        \n",
    "        for reg in registros:\n",
    "            coord_str = f\"{reg['coord_geocode'][0]}, {reg['coord_geocode'][1]}\" if reg['coord_geocode'][0] else \"N/A\"\n",
    "            coordenadas_unicas.add(coord_str)\n",
    "            print(f\"   • Nº {reg['numero']}: {coord_str} (Fonte: {reg['fonte']})\")\n",
    "        \n",
    "        print(f\"   📍 Coordenadas distintas: {len(coordenadas_unicas)}\")\n",
    "        if len(coordenadas_unicas) == 1 and len(registros) > 1:\n",
    "            print(f\"   ⚠️  ALERTA: Todos os números retornaram a MESMA coordenada!\")\n",
    "        elif len(coordenadas_unicas) > 1:\n",
    "            print(f\"   ✅ Diferentes coordenadas por número - FUNCIONANDO!\")\n",
    "    \n",
    "    return resultados_teste\n",
    "\n",
    "# ✅ TERCEIRO: Executar o teste\n",
    "print(\"🚀 INICIANDO TESTE COMPLETO...\")\n",
    "resultados = teste_processamento_manual()\n",
    "print(\"\\n🎉 TESTE CONCLUÍDO!\")"
